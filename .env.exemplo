# ============================================================
# Snoopy - Variáveis de Ambiente
# Renomeie para .env e ajuste conforme sua configuração
# ============================================================

# Backend de IA (ollama | lm_studio | openai_compativel)
SNOOPY_BACKEND=ollama
SNOOPY_MODELO=llama3.2:3b
SNOOPY_URL_IA=http://localhost:11434

# Whisper
SNOOPY_WHISPER_MODELO=base

# Logs
SNOOPY_LOG_NIVEL=INFO   # DEBUG | INFO | WARNING | ERROR

# TTS
SNOOPY_TTS_MOTOR=piper
